# Railway deployment environment variables
# Copy these to Railway → Variables panel

# Required: PostgreSQL connection string (Railway provides this automatically if you add Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required: Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Required: Mini App public URL (your Railway domain, e.g. https://your-app.railway.app)
MINI_APP_URL=https://your-app.railway.app

# Required: Session secret (random string)
SESSION_SECRET=your_random_secret_here

# Auto-set by Railway/nixpacks — do NOT set manually
# PORT=8080
# NODE_ENV=production
# BASE_PATH=/
